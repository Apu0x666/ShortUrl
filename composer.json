{
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3.3",
        "symfony/amqp-messenger": "^7.1",
        "symfony/console": "^7.1",
        "symfony/dotenv": "^7.1",
        "symfony/framework-bundle": "^7.1",
        "symfony/flex": "^2",
        "symfony/http-foundation": "^7.1",
        "symfony/messenger": "^7.1",
        "symfony/runtime": "^7.1",
        "symfony/serializer": "^7.1",
        "symfony/validator": "^7.1",
        "symfony/yaml": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3",
        "symfony/browser-kit": "^7.1",
        "symfony/css-selector": "^7.1",
        "symfony/phpunit-bridge": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "APP_ENV=test APP_DEBUG=1 php ./vendor/bin/phpunit"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^7.1"
        }
    }
}
